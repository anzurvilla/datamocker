{
  "name": "datamocker",
  "version": "1.0.0",
  "description": "Data-Mocker: Random Data Generator",
  "main": "",
  "scripts": {
    "build": "pkg .",
    "dev": "nodemon --ignore data/*.json --trace-warnings src/app.js",
    "start": "node src/app.js",
    "test": "mocha test/app.test.js"
  },
  "dependencies": {
    "clear": "^0.1.0",
    "colors": "^1.4.0",
    "figlet": "^1.10.0",
    "inquirer": "^13.3.0",
    "moment": "^2.30.1"
  },
  "devDependencies": {
    "chai": "^6.2.2",
    "mocha": "^11.7.5",
    "nodemon": "^3.1.14"
  },
  "overrides": {
    "diff": "8.0.2",
    "serialize-javascript": "7.0.3"
  },
  "bin": "src/app.js",
  "pkg": {
    "assets": [
      "./node_modules/*",
      "./assets/**/*"
    ],
    "scripts": "src/**/*.js",
    "outputPath": "dist",
    "targets": [
      "node16-win-x64"
    ]
  },
  "keywords": [
    "datamocker",
    "random",
    "data",
    "generator"
  ],
  "author": "Anzur Villa",
  "license": "MIT"
}
